{
  "name": "visualizer-mathematics",
  "version": "1.0.0",
  "description": "2D/3D Cartesian Coordinate Curve Visualizer with desktop support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "vendor:update": "node -e \"const fs=require('fs');fs.cpSync('node_modules/plotly.js-dist-min/plotly.min.js','src/vendor/plotly.min.js');fs.cpSync('node_modules/mathjs/lib/browser/math.js','src/vendor/math.min.js');console.log('Vendor files updated.');\""
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "mathjs": "^15.1.1",
    "plotly.js-dist-min": "^3.4.0"
  },
  "build": {
    "appId": "com.visualizer.mathematics",
    "productName": "Mathematics Curve Visualizer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    },
    "linux": {
      "target": "AppImage",
      "category": "Education"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    }
  }
}
